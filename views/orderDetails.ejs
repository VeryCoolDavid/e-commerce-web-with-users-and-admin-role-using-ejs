<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Order Details</title>
  </head>

  <body class="bg-gray-100">
    <%- include('./partials/header') %>

    <div class="w-full min-h-screen">
      <div class="max-w-4xl mx-auto mt-10 bg-white p-6 rounded shadow">
        <!-- Order Info -->
        <div class="border-b pb-4 mb-4">
          <h1 class="text-2xl font-semibold mb-2">Order Details</h1>

          <p><span class="font-medium">Order ID:</span> <%= order._id %></p>

          <p>
            <span class="font-medium">Order Date:</span> <%=
            order.createdAt.toDateString() %>
          </p>
          <p>
            <span class="font-medium">Expected Delivery:</span><%= new Date(new
            Date(order.createdAt).setDate(new Date(order.createdAt).getDate() +
            7)).toDateString() %>
          </p>

          <div>
            <p class="text-sm text-gray-500">STATUS</p>
            <% if(order.status ==="Cancelled"){%>
            <p class="text-red-600 font-medium">
              <i class="ri-close-line"></i><%= order.status %>
            </p>
            <%} else if (order.status==="Delivered"){%>
            <p class="text-green-600 font-medium"><%= order.status %></p>
            <%} else{%>
            <p class="text-yellow-600 font-medium"><%= order.status %></p>
            <%} %>
          </div>
        </div>

        <!-- Products -->
        <div>
          <% order.items.forEach(item => { %>

          <div class="flex items-center gap-4 border-b py-4">
            <!-- Image -->
            <div class="w-24 h-24">
              <img
                src="/uploads/<%= item.product.image %>"
                class="w-full h-full object-contain rounded"
              />
            </div>

            <!-- Info -->
            <div class="flex-1">
              <h3 class="text-lg font-medium"><%= item.product.name %></h3>

              <p class="text-gray-600 text-sm">
                Quantity: <%= item.quantity %>
              </p>

              <p class="text-gray-600 text-sm">Price: ₹ <%= item.price %></p>
            </div>
          </div>

          <% }) %>
        </div>

        <!-- Total -->
        <div class="mt-6 flex justify-between text-xl font-semibold">
          <span>Total Amount</span>
          <span class="text-green-600">₹ <%= order.totalAmount %></span>
        </div>
      </div>
    </div>
    <%- include('./partials/footer') %>
  </body>
</html>
