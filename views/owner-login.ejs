<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Document</title>
  </head>
  <body>
    <% if(error.length>0){ %>
    <div
      class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-red-500"
    >
      <span class="inline-block mt-1 mb-1 text-white"> <%= error[0] %></span>
    </div>

    <% } %>
    <div class="w-full h-screen flex justify-center px-20">
      <div class="w-1/2 flex items-center justify-center h-screen">
        <div class="w-full px-32">
          <h4 class="text-2xl capitalize mb-5">Admin Access</h4>
          <form action="/admin/login" method="post">
            <input
              class="block bg-zinc-100 w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
              type="email"
              placeholder="Email"
              name="email"
            />
            <input
              class="block bg-zinc-100 w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
              type="password"
              placeholder="Password"
              name="password"
            />
            <input
              class="px-5 rounded-full py-3 mt-2 bg-blue-500 text-white"
              type="submit"
              value="Login"
            />
          </form>
        </div>
      </div>
    </div>
    <%- include('./partials/footer') %>
  </body>
</html>
