<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css"
      rel="stylesheet"
    />
  </head>

  <body class="bg-gray-100">
    <div class="max-w-4xl mx-auto p-6">
      <!-- Profile Card -->
      <div class="bg-white rounded shadow p-6 flex items-center gap-6">
        <!-- Avatar -->
        <div
          class="w-24 h-24 rounded-full bg-gray-200 flex items-center justify-center overflow-hidden"
        >
          <img
            src="<%= user?.profilePic || 'https://cdn-icons-png.flaticon.com/512/149/149071.png' %>"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- User Info -->
        <div>
          <h2 class="text-2xl font-bold"><%= user.username %></h2>
          <p class="text-gray-500"><%= user.email %></p>
        </div>
        <!-- upload picture-->
      </div>

      <!-- Actions -->
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Wishlist -->
        <a
          href="/users/wishlist"
          class="bg-white p-4 rounded shadow flex items-center justify-between hover:shadow-md transition"
        >
          <div class="flex items-center gap-3">
            <i class="ri-heart-line text-xl text-red-500"></i>
            <span class="font-medium">My Wishlist</span>
          </div>
          <i class="ri-arrow-right-s-line"></i>
        </a>

        <!-- Orders -->
        <a
          href="/users/order"
          class="bg-white p-4 rounded shadow flex items-center justify-between hover:shadow-md transition"
        >
          <div class="flex items-center gap-3">
            <i class="ri-shopping-bag-line text-xl text-blue-500"></i>
            <span class="font-medium">My Orders</span>
          </div>
          <i class="ri-arrow-right-s-line"></i>
        </a>
      </div>
    </div>
  </body>
</html>
